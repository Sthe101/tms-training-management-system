# Database (use pooler URL for IPv4 support)
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# API
PORT=3001
NODE_ENV=development   # Set to "production" in prod — affects cookie SameSite + Secure flags

# CORS — must match your deployed frontend URL exactly (no trailing slash)
FRONTEND_URL=http://localhost:3000

# JWT (REQUIRED - generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_EXPIRATION=7d

# ---- PRODUCTION NOTES ----
# 1. NODE_ENV=production enables SameSite=None;Secure cookies (required for cross-origin)
# 2. FRONTEND_URL must be your deployed frontend domain (e.g. https://tms.vercel.app)
# 3. JWT_SECRET must be a strong random secret — never commit the real value
# 4. DATABASE_URL should use the Supabase connection pooler URL for production
