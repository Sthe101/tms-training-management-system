generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Slice 1: Authentication
enum Role {
  ADMIN
  MANAGER
  CLERK
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Slice 4: Training Categories
model TrainingCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
}

// Slice 6: Employees
enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum EmployeeRole {
  EMPLOYEE
  MANAGER
}

model Employee {
  id             String         @id @default(cuid())
  name           String
  employeeNumber String         @unique
  departmentId   String
  department     Department     @relation(fields: [departmentId], references: [id])
  status         EmployeeStatus @default(ACTIVE)
  role           EmployeeRole   @default(EMPLOYEE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// Slice 2: Divisions & Departments
model Division {
  id          String       @id @default(cuid())
  name        String       @unique
  createdAt   DateTime     @default(now())
  departments Department[]
}

model Department {
  id         String     @id @default(cuid())
  name       String
  divisionId String
  division   Division   @relation(fields: [divisionId], references: [id], onDelete: Cascade)
  employees  Employee[]
  createdAt  DateTime   @default(now())
}
